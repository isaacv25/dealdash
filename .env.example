DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dealdash
SESSION_SECRET=replace-with-a-long-random-string
# Shared secret for the /api/cron/post-payments route. Vercel Cron automatically sends this value
# as `Authorization: Bearer <CRON_SECRET>` when it invokes the endpoint -- set the same value here
# and in the Vercel project's environment variables. Generate with e.g. `openssl rand -hex 32`.
CRON_SECRET=replace-with-a-long-random-string
