generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id            String       @id @default(cuid())
  name          String
  slug          String       @unique
  users         User[]
  fundedDeals   FundedDeal[]
  pipelineDeals PipelineDeal[]
  followUps     FollowUpItem[]
  importBatches ImportBatch[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model User {
  id                      String          @id @default(cuid())
  companyId               String
  company                 Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  firstName               String
  lastName                String
  username                String          @unique
  passwordHash            String
  role                    String          @default("user")
  hideFinancialsByDefault Boolean         @default(true)
  sessions                Session[]
  createdFundedDeals      FundedDeal[]    @relation("FundedDealCreatedBy")
  updatedFundedDeals      FundedDeal[]    @relation("FundedDealUpdatedBy")
  createdPipelineDeals    PipelineDeal[]  @relation("PipelineDealCreatedBy")
  updatedPipelineDeals    PipelineDeal[]  @relation("PipelineDealUpdatedBy")
  createdFollowUps        FollowUpItem[]  @relation("FollowUpCreatedBy")
  updatedFollowUps        FollowUpItem[]  @relation("FollowUpUpdatedBy")
  createdImportBatches    ImportBatch[]   @relation("ImportBatchCreatedBy")
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model FundedDeal {
  id                     String    @id @default(cuid())
  companyId              String
  company                Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdByUserId        String?
  createdByUser          User?     @relation("FundedDealCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUserId        String?
  updatedByUser          User?     @relation("FundedDealUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  businessName           String
  contactName            String
  phone                  String?
  email                  String?
  fundedDate             DateTime?
  funder                 String?
  fundedAmount           Float     @default(0)
  factorRate             Float     @default(1)
  termValue              Int       @default(0)
  termUnit               String    @default("weeks")
  paymentAmount          Float     @default(0)
  paymentFrequency       String    @default("weekly")
  syndicationPercent     Float     @default(0)
  pointsPercent          Float     @default(0)
  housePointsPercent     Float     @default(0)
  commissionPercent      Float     @default(0)
  commissionAmount       Float     @default(0)
  commissionStatus       String    @default("pending")
  clawbackAmount         Float     @default(0)
  statusRaw              String    @default("Active")
  statusStage            String    @default("active")
  notes                  String    @default("")
  sourceLabel            String    @default("manual")
  manualBalanceRemaining Float?
  manualRenewalDate      DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@index([companyId, fundedDate])
}

model PipelineDeal {
  id                 String    @id @default(cuid())
  companyId          String
  company            Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdByUserId    String?
  createdByUser      User?     @relation("PipelineDealCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUserId    String?
  updatedByUser      User?     @relation("PipelineDealUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  contactName        String
  businessName       String
  phone              String?
  email              String?
  city               String?
  state              String?
  submittedDate      DateTime?
  requestLabel       String    @default("")
  requestedAmountMin Float?
  requestedAmountMax Float?
  statusRaw          String    @default("")
  stage              String    @default("new-lead")
  notes              String    @default("")
  sheetLabel         String    @default("")
  nextFollowUpDate   DateTime?
  sourceLabel        String    @default("manual")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([companyId, stage])
}

model FollowUpItem {
  id               String    @id @default(cuid())
  companyId        String
  company          Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdByUserId  String?
  createdByUser    User?     @relation("FollowUpCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUserId  String?
  updatedByUser    User?     @relation("FollowUpUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  contactName      String
  businessName     String
  phone            String?
  email            String?
  requestLabel     String    @default("")
  notes            String    @default("")
  lastContactLabel String    @default("")
  dueDate          DateTime?
  priority         String    @default("medium")
  appSubmitted     Boolean   @default(false)
  completed        Boolean   @default(false)
  sheetLabel       String    @default("")
  sourceLabel      String    @default("manual")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([companyId, completed])
}

model ImportBatch {
  id             String    @id @default(cuid())
  companyId      String
  company        Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdByUserId String?
  createdByUser  User?     @relation("ImportBatchCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  filename       String
  importType     String
  rowsImported   Int
  rowsSkipped    Int
  detectedColumns String[]
  importedAt     DateTime
  notes          String?
  createdAt      DateTime  @default(now())

  @@index([companyId, importedAt])
}
