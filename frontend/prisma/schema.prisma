generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id            String       @id @default(cuid())
  name          String
  slug          String       @unique
  users         User[]
  fundedDeals   FundedDeal[]
  pipelineDeals PipelineDeal[]
  followUps     FollowUpItem[]
  importBatches ImportBatch[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model User {
  id                      String          @id @default(cuid())
  companyId               String
  company                 Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  firstName               String
  lastName                String
  username                String          @unique
  passwordHash            String
  role                    String          @default("user")
  hideFinancialsByDefault Boolean         @default(true)
  sessions                Session[]
  createdFundedDeals      FundedDeal[]    @relation("FundedDealCreatedBy")
  updatedFundedDeals      FundedDeal[]    @relation("FundedDealUpdatedBy")
  createdPipelineDeals    PipelineDeal[]  @relation("PipelineDealCreatedBy")
  updatedPipelineDeals    PipelineDeal[]  @relation("PipelineDealUpdatedBy")
  createdFollowUps        FollowUpItem[]  @relation("FollowUpCreatedBy")
  updatedFollowUps        FollowUpItem[]  @relation("FollowUpUpdatedBy")
  createdImportBatches    ImportBatch[]   @relation("ImportBatchCreatedBy")
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model FundedDeal {
  id                     String    @id @default(cuid())
  companyId              String
  company                Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdByUserId        String?
  createdByUser          User?     @relation("FundedDealCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUserId        String?
  updatedByUser          User?     @relation("FundedDealUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  businessName           String
  contactName            String
  phone                  String?
  email                  String?
  fundedDate             DateTime?
  funder                 String?
  fundedAmount           Float     @default(0)
  factorRate             Float     @default(1)
  termValue              Int       @default(0)
  termUnit               String    @default("weeks")
  paymentAmount          Float     @default(0)
  paymentFrequency       String    @default("weekly")
  syndicationPercent     Float     @default(0)
  pointsPercent          Float     @default(0)
  housePointsPercent     Float     @default(0)
  commissionPercent      Float     @default(0)
  commissionAmount       Float     @default(0)
  commissionStatus       String    @default("pending")
  clawbackAmount         Float     @default(0)
  statusRaw              String    @default("Active")
  statusStage            String    @default("active")
  fundedTags             String[]  @default([])
  notes                  String    @default("")
  sourceLabel            String    @default("manual")
  manualBalanceRemaining Float?
  manualRenewalDate      DateTime?
  deletedAt              DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  // Weekday selected for weekly payment schedules (0 = Sunday .. 6 = Saturday). Null until a
  // schedule has been generated, at which point it is required for weekly-frequency deals.
  paymentWeekday Int?

  // Anchor date for the first scheduled payment. Falls back to fundedDate when unset so legacy
  // deals keep working without a migration backfill.
  firstPaymentDate DateTime?

  // Marks the deal fully repaid once the persisted schedule balance reaches zero via the cron poster.
  scheduleCompletedAt DateTime?

  // --- Advanced adjustments: "Override Calculated Balance" ---
  // Superseded by these fields; manualBalanceRemaining above is kept only as a legacy read-fallback
  // for deals that predate this feature (see migrateLegacyBalanceOverrides in workspace.ts) and is
  // never written by new code.
  balanceOverrideCents          Int?
  balanceOverrideEffectiveDate  DateTime?
  balanceOverrideReason         String?
  balanceOverrideSetByUserId    String?
  balanceOverrideSetAt          DateTime?

  paymentSchedule PaymentScheduleEntry[]
  adjustments     PaymentAdjustment[]
  auditEntries    AuditEntry[]

  @@index([companyId, fundedDate])
  @@index([companyId, deletedAt])
}

enum ScheduleEntryStatus {
  pending
  posted
  skipped
  paused
}

/**
 * One row per contractual payment. Persisted server-side (not derived client-side) so the midnight
 * cron job has an authoritative, idempotent record of what is due and what has already posted.
 */
model PaymentScheduleEntry {
  id                   String              @id @default(cuid())
  fundedDealId         String
  fundedDeal           FundedDeal          @relation(fields: [fundedDealId], references: [id], onDelete: Cascade)
  sequence             Int
  dueDate              DateTime
  scheduledAmountCents Int
  status               ScheduleEntryStatus @default(pending)
  postedAt             DateTime?
  postedAmountCents    Int?
  postingSource        String?
  adjustmentId         String?
  adjustment           PaymentAdjustment?  @relation(fields: [adjustmentId], references: [id], onDelete: SetNull)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  // Guarantees the cron job (or a retried/duplicate invocation) can never create or post the same
  // scheduled payment twice.
  @@unique([fundedDealId, sequence])
  // Cron sweep query: "find pending entries due on or before now".
  @@index([status, dueDate])
}

enum PaymentAdjustmentType {
  lowered
  pause
}

/**
 * A lowered-payment period or a pause. Historical posted payments are never rewritten by these;
 * they only affect schedule entries still pending regeneration/posting.
 */
model PaymentAdjustment {
  id              String                 @id @default(cuid())
  fundedDealId    String
  fundedDeal      FundedDeal             @relation(fields: [fundedDealId], references: [id], onDelete: Cascade)
  type            PaymentAdjustmentType
  newAmountCents  Int?
  effectiveDate   DateTime
  endDate         DateTime?
  reason          String
  active          Boolean                @default(true)
  createdByUserId String?
  createdAt       DateTime               @default(now())

  scheduleEntries PaymentScheduleEntry[]

  @@index([fundedDealId, active])
}

/**
 * Append-only history of material deal changes: balance overrides, payment adjustments, and
 * schedule recasts. Never mutated after creation.
 */
model AuditEntry {
  id             String    @id @default(cuid())
  fundedDealId   String
  fundedDeal     FundedDeal @relation(fields: [fundedDealId], references: [id], onDelete: Cascade)
  category       String
  previousValue  Json?
  newValue       Json?
  effectiveDate  DateTime?
  reason         String?
  userId         String?
  createdAt      DateTime  @default(now())

  @@index([fundedDealId, createdAt])
}

/**
 * One row per cron sweep. Lets the poster detect and safely catch up a missed hourly run, and
 * gives an admin an audit trail of automated posting activity.
 */
model CronRunLog {
  id               String   @id @default(cuid())
  runAt            DateTime @default(now())
  windowStart      DateTime
  windowEnd        DateTime
  entriesEvaluated Int
  entriesPosted    Int
  errorCount       Int      @default(0)
  errorDetail      String?
  triggeredBy      String

  @@index([runAt])
}

model PipelineDeal {
  id                 String    @id @default(cuid())
  companyId          String
  company            Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdByUserId    String?
  createdByUser      User?     @relation("PipelineDealCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUserId    String?
  updatedByUser      User?     @relation("PipelineDealUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  contactName        String
  businessName       String
  phone              String?
  email              String?
  city               String?
  state              String?
  submittedDate      DateTime?
  requestLabel       String    @default("")
  requestedAmountMin Float?
  requestedAmountMax Float?
  statusRaw          String    @default("")
  stage              String    @default("new-lead")
  notes              String    @default("")
  sheetLabel         String    @default("")
  nextFollowUpDate   DateTime?
  sourceLabel        String    @default("manual")
  deletedAt          DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([companyId, stage])
  @@index([companyId, deletedAt])
}

model FollowUpItem {
  id               String    @id @default(cuid())
  companyId        String
  company          Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdByUserId  String?
  createdByUser    User?     @relation("FollowUpCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUserId  String?
  updatedByUser    User?     @relation("FollowUpUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  contactName      String
  businessName     String
  phone            String?
  email            String?
  requestLabel     String    @default("")
  notes            String    @default("")
  lastContactLabel String    @default("")
  dueDate          DateTime?
  priority         String    @default("medium")
  appSubmitted     Boolean   @default(false)
  completed        Boolean   @default(false)
  sheetLabel       String    @default("")
  sourceLabel      String    @default("manual")
  deletedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([companyId, completed])
  @@index([companyId, deletedAt])
}

model ImportBatch {
  id             String    @id @default(cuid())
  companyId      String
  company        Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdByUserId String?
  createdByUser  User?     @relation("ImportBatchCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  filename       String
  importType     String
  rowsImported   Int
  rowsSkipped    Int
  detectedColumns String[]
  importedAt     DateTime
  notes          String?
  createdAt      DateTime  @default(now())

  @@index([companyId, importedAt])
}
